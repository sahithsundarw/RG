# ── Required ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
GITHUB_WEBHOOK_SECRET=your-hmac-secret-here
GITHUB_TOKEN=ghp_...

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── ChromaDB ───────────────────────────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8001

# ── Optional overrides ─────────────────────────────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO
ENVIRONMENT=local
AGENT_TIMEOUT_SECONDS=90
WORKER_CONCURRENCY=4
HITL_BLOCK_MERGE_ON_CRITICAL=true
